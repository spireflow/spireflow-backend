{
  "name": "spireflow-backend",
  "version": "2.0.0",
  "description": "Open source Node.js backend for Spireflow dashboard",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Mateusz Wyrębek",
    "email": "mateusz.wyrebek@gmail.com",
    "url": "https://matt765.dev/"
  },
  "main": "build/src/server.js",
  "scripts": {
    "postinstall": "echo 'Skipping prisma generate during install'",
    "build": "tsc && node --input-type=commonjs -e \"require('fs').cpSync('src/generated','build/src/generated',{recursive:true})\"",
    "start": "node ./build/src/server.js",
    "dev": "nodemon -q --watch ./build/src --delay 500ms ./build/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=7.19"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "graphql": "^16.13.1",
    "graphql-type-json": "^0.3.2",
    "mercurius": "^16.8.0",
    "pg": "^8.19.0",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.11",
    "@vitest/ui": "^4.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  }
}
